+def resolve_snapshot_path(snapshot_path: str | None, evidence_dir: Path = DEFAULT_EVIDENCE_DIR) -> Path:
+    if snapshot_path:
+        path = Path(snapshot_path)
+        if path.is_dir():
+            path = path / "run.json"
+        if not path.exists():
+            raise FileNotFoundError(f"run snapshot not found: {path}")
+        return path
+
+    latest = latest_snapshot_path(evidence_dir)
+    if latest is None:
+        raise FileNotFoundError(f"no run snapshots found in: {evidence_dir}")
+    return latest
+
+
+def latest_snapshot_path(evidence_dir: Path = DEFAULT_EVIDENCE_DIR) -> Path | None:
+    candidates = list(evidence_dir.glob("*/run.json"))
+    if not candidates:
+        return None
+
+    def sort_key(path: Path) -> tuple[str, float, str]:
+        try:
+            payload = read_snapshot(path)
+            created_at = str(payload.get("created_at", ""))
+        except (OSError, json.JSONDecodeError):
+            created_at = ""
+        return (created_at, path.stat().st_mtime, str(path))
+
+    return max(candidates, key=sort_key)
+
+
+def read_snapshot(snapshot_path: Path) -> dict[str, Any]:
+    return json.loads(snapshot_path.read_text(encoding="utf-8"))
+
+
+def generate_issues_from_snapshot(payload: dict[str, Any], snapshot_path: Path) -> list[GeneratedIssue]:
+    run_id = _string_field(payload, "run_id", "unknown-run")
+    prompt = _string_field(payload, "prompt", "Review run snapshot")
+    status = _string_field(payload, "status", "unknown")
+    result = _string_field(payload, "result", "")
+    product_path = _string_field(payload, "product_path", "")
+    issues: list[GeneratedIssue] = []
+
+    if status != "completed":
+        issues.append(
+            GeneratedIssue(
+                issue_id=f"{run_id}-issue-001",
+                title=f"Investigate {status} agent run",
+                summary=f"Snapshot status is {status}; inspect the run trajectory and complete the requested work.",
+                severity="high",
+                source_run_id=run_id,
+                source_snapshot=str(snapshot_path),
+            )
+        )
+
+    title = _issue_title_from_prompt(prompt)
+    summary_parts = [f"Generated from snapshot {run_id}."]
+    if product_path:
+        summary_parts.append(f"Product path: {product_path}.")
+    if result:
+        summary_parts.append(f"Result: {result}")
+    issues.append(
+        GeneratedIssue(
+            issue_id=f"{run_id}-issue-{len(issues) + 1:03d}",
+            title=title,
+            summary=" ".join(summary_parts),
+            severity="normal",
+            source_run_id=run_id,
+            source_snapshot=str(snapshot_path),
+        )
+    )
+    return issues
+
+
