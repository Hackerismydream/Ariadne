+def _issue_title_from_prompt(prompt: str) -> str:
+    normalized = " ".join(prompt.split())
+    if not normalized:
+        return "Review run snapshot"
+    if len(normalized) <= 80:
+        return normalized
+    return normalized[:77].rstrip() + "..."
+
+
+def _string_field(payload: dict[str, Any], key: str, default: str) -> str:
+    value = payload.get(key, default)
+    if value is None:
+        return default
+    return str(value)
+
